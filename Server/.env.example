# Server Configuration
PORT=3000

# Security (JWT)
JWT_SECRET=super_secret_jwt_key_change_me_in_prod
JWT_REFRESH_SECRET=super_secret_refresh_key_change_me_in_prod

# Lockout Rule Configuration (in minutes)
LOGIN_LOCK_MINUTES=30

# Database Connection
# Neon/Supabase/Railway Postgres connection string
# DATABASE_URL is for the pooled connection (?pgbouncer=true)
DATABASE_URL="postgresql://user:password@host:5432/transitops?pgbouncer=true"

# DIRECT_URL is for the direct connection (used by Prisma for migrations)
DIRECT_URL="postgresql://user:password@host:5432/transitops"
