generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------
// ENUMS
// -----------------------------------------
enum Role {
  SUPER_ADMIN
  BRANCH_ADMIN
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ExpenseType {
  TOLL
  OTHER
}

// -----------------------------------------
// MODELS
// -----------------------------------------

model Branch {
  id            String  @id @default(uuid())
  name          String
  address       String
  city          String
  state         String
  contactNumber String
  adminId       String? // Optional ID of the user managing this branch
  isActive      Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users       User[]
  vehicles    Vehicle[]
  drivers     Driver[]
  trips       Trip[]
  maintenance MaintenanceLog[]

  @@index([isActive])
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  name         String
  role         Role

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  refreshTokens RefreshToken[]
  tripsCreated  Trip[]         @relation("TripCreator")

  @@index([branchId, deletedAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model Vehicle {
  id                 String @id @default(uuid())
  registrationNumber String @unique
  name               String
  model              String
  type               String
  maxLoadCapacity    Float
  odometer           Float
  acquisitionCost    Float

  status VehicleStatus @default(AVAILABLE)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status])
  @@index([branchId, status, deletedAt])
}

model Driver {
  id                String       @id @default(uuid())
  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Float
  status            DriverStatus @default(AVAILABLE)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  trips Trip[]

  @@index([status])
  @@index([licenseExpiryDate])
  @@index([branchId, status, deletedAt])
}

model Trip {
  id          String @id @default(uuid())
  source      String
  destination String

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id], onDelete: Restrict)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   User   @relation("TripCreator", fields: [createdById], references: [id], onDelete: Restrict)

  cargoWeight     Float
  plannedDistance Float
  actualDistance  Float?
  finalOdometer   Float?
  revenue         Float?

  status       TripStatus @default(DRAFT)
  dispatchedAt DateTime?
  completedAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  fuelLogs FuelLog[]
  expenses Expense[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([branchId, status, deletedAt])
  @@index([createdById])
}

model MaintenanceLog {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  serviceType    String
  description    String?
  cost           Float
  date           DateTime
  startedAt      DateTime?
  completedAt    DateTime?
  technicianName String?

  status MaintenanceStatus @default(PENDING)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([vehicleId])
  @@index([status])
  @@index([branchId])
}

model FuelLog {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  tripId String?
  trip   Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)

  liters      Float
  cost        Float
  date        DateTime
  fuelStation String?
  receiptNo   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([vehicleId, date, deletedAt])
  @@index([tripId])
}

model Expense {
  id String @id @default(uuid())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  tripId String?
  trip   Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)

  type   ExpenseType
  amount Float
  date   DateTime

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([vehicleId])
  @@index([tripId])
}
